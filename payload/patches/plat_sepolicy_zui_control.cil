;; ZuiControl init bind-mount bridge.
;; The shell-domain daemon only requests init actions through zui_control.* properties.
;; Init performs the file bind mounts, then the daemon verifies /proc/mounts.
(type zui_control_service)
(typeattributeset service_manager_type (zui_control_service))
(allow system_server zui_control_service (service_manager (add find)))
(allow priv_app zui_control_service (service_manager (find)))
(allow init system_file (file (mounton)))
