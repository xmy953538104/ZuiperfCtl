#!/system/bin/sh

DATA_ROOT=/data/local/tmp/zui_perfctl
PERF_DIR=$DATA_ROOT/perfctl
DONE_DIR=$PERF_DIR/processed
ZUI_DIR=$DATA_ROOT/zuipp
ASOUL_DIR=$DATA_ROOT/asoul
REFRESH_DIR=$DATA_ROOT/refresh
PROFILE_DIR=$DATA_ROOT/profiles
LOG_DIR=$DATA_ROOT/log
LOG_FILE=$LOG_DIR/perfctld.log
STATUS_FILE=$PERF_DIR/status.prop
ADB_REQUEST=$PERF_DIR/request.prop
LAST_SETTINGS_ID_FILE=$PERF_DIR/last_settings_request_id
LAST_SETTINGS_TEXT_FILE=$PERF_DIR/last_settings_request_text
APP_PACKAGE=com.zui.zuiperfctl
APP_SERVICE_COMPONENT=com.zui.zuiperfctl/com.zui.perfctl.PerfCtlQuickService
PROP_ZUIPP=zui_perfctl.zuipp
PROP_ASOUL=zui_perfctl.asoul

SYSTEM_GAME_POLICY=/system/etc/game_policy.xml
SYSTEM_PERF_CONFIG=/system/etc/performanceconfig.xml
SYSTEM_ASOPT=/system/etc/asopt.conf

DEFAULT_GAME_POLICY=/system/etc/zui_perfctl/default_game_policy.xml
DEFAULT_PERF_CONFIG=/system/etc/zui_perfctl/default_performanceconfig.xml
DEFAULT_ASOPT=/system/etc/zui_perfctl/default_asopt.conf
DEFAULT_REFRESH_RULES=/system/etc/zui_perfctl/default_refresh_rules.prop

WORK_GAME_POLICY=$ZUI_DIR/game_policy.xml
WORK_PERF_CONFIG=$ZUI_DIR/performanceconfig.xml
WORK_ASOPT=$ASOUL_DIR/asopt.conf
REFRESH_RULES=$REFRESH_DIR/rules.prop
APP_PROFILES=$PROFILE_DIR/apps.prop
ZUI_ENABLED=$ZUI_DIR/enabled.flag
ASOUL_ENABLED=$ASOUL_DIR/enabled.flag
REFRESH_ENABLED=$REFRESH_DIR/enabled.flag

REQ_ID_KEY=zui_perfctl_request_id
REQ_TEXT_KEY=zui_perfctl_request_text
REQ_CMD_KEY=zui_perfctl_cmd
REQ_RATE_KEY=zui_perfctl_rate
REQ_PACKAGE_KEY=zui_perfctl_package
REQ_PROFILE_REFRESH_KEY=zui_perfctl_profile_refresh
REQ_PROFILE_ZUIPP_KEY=zui_perfctl_profile_zuipp
REQ_PROFILE_ASOUL_KEY=zui_perfctl_profile_asoul
STATUS_TIME_KEY=zui_perfctl_status_time
STATUS_LAST_KEY=zui_perfctl_status_last
STATUS_TEXT_KEY=zui_perfctl_status_text
RULES_TEXT_KEY=zui_perfctl_refresh_rules_text
PROFILES_TEXT_KEY=zui_perfctl_profiles_text
AUTO_REFRESH_KEY=zui_perfctl_auto_refresh

LAST_TOP_APP=
LAST_REFRESH_RATE=
LAST_SETTINGS_REQUEST_ID=
LAST_SETTINGS_REQUEST_TEXT=
EMPTY_TOP_TICKS=0

ts() {
    date '+%Y-%m-%d %H:%M:%S'
}

settings_get_clean() {
    value="$(settings get system "$1" 2>/dev/null)"
    if [ "$value" = "null" ]; then
        value=
    fi
    echo "$value"
}

settings_put_quiet() {
    settings put system "$1" "$2" >/dev/null 2>&1
}

settings_delete_quiet() {
    settings delete system "$1" >/dev/null 2>&1
}

log_line() {
    mkdir -p "$LOG_DIR"
    echo "$(ts) $*" >> "$LOG_FILE"
}

set_status() {
    mkdir -p "$PERF_DIR"
    {
        echo "time=$(ts)"
        for line in "$@"; do
            echo "$line"
        done
    } > "$STATUS_FILE"
    chmod 0664 "$STATUS_FILE" 2>/dev/null

    last=
    for line in "$@"; do
        case "$line" in
            last=*) last="${line#last=}" ;;
        esac
    done
    settings_put_quiet "$STATUS_TIME_KEY" "$(ts)"
    settings_put_quiet "$STATUS_LAST_KEY" "$last"
    if [ -s "$STATUS_FILE" ]; then
        status_text="$(tr '\n' ';' < "$STATUS_FILE" 2>/dev/null)"
        settings_put_quiet "$STATUS_TEXT_KEY" "$status_text"
    fi
}

copy_if_missing() {
    src="$1"
    dst="$2"
    if [ -s "$dst" ]; then
        return 0
    fi
    if [ -s "$src" ]; then
        cp "$src" "$dst" && chmod 0664 "$dst"
    fi
}

copy_work_file() {
    live="$1"
    fallback="$2"
    dst="$3"
    name="$4"

    if [ ! -s "$dst" ]; then
        if [ -s "$live" ]; then
            cp "$live" "$dst" && chmod 0664 "$dst"
            log_line "$name initialized from live system file"
            return 0
        fi
        copy_if_missing "$fallback" "$dst"
        log_line "$name initialized from fallback file"
        return 0
    fi

    if [ -s "$live" ] && [ -s "$fallback" ] && cmp -s "$dst" "$fallback" && ! cmp -s "$live" "$fallback"; then
        cp "$live" "$dst" && chmod 0664 "$dst"
        log_line "$name migrated from fallback to live system file"
    fi
}

publish_refresh_state() {
    rules_text=
    if [ -s "$REFRESH_RULES" ]; then
        rules_text="$(grep -v '^[[:space:]]*#' "$REFRESH_RULES" 2>/dev/null | grep -v '^[[:space:]]*$' 2>/dev/null)"
    fi
    settings_put_quiet "$RULES_TEXT_KEY" "$rules_text"
    if [ -f "$REFRESH_ENABLED" ]; then
        settings_put_quiet "$AUTO_REFRESH_KEY" "1"
    else
        settings_put_quiet "$AUTO_REFRESH_KEY" "0"
    fi
}

publish_profile_state() {
    dedupe_profiles_file
    profiles_text=
    if [ -s "$APP_PROFILES" ]; then
        profiles_text="$(grep -v '^[[:space:]]*#' "$APP_PROFILES" 2>/dev/null | grep -v '^[[:space:]]*$' 2>/dev/null)"
    fi
    settings_put_quiet "$PROFILES_TEXT_KEY" "$profiles_text"
}

publish_state() {
    publish_refresh_state
    publish_profile_state
}

grant_app_permissions() {
    pm grant "$APP_PACKAGE" android.permission.POST_NOTIFICATIONS >/dev/null 2>&1
    appops set "$APP_PACKAGE" POST_NOTIFICATION allow >/dev/null 2>&1
    appops set "$APP_PACKAGE" WRITE_SETTINGS allow >/dev/null 2>&1
}

start_app_service() {
    am start-foreground-service -n "$APP_SERVICE_COMPONENT" >/dev/null 2>&1 ||
        am startservice -n "$APP_SERVICE_COMPONENT" >/dev/null 2>&1
}

init_dirs() {
    mkdir -p "$PERF_DIR" "$DONE_DIR" "$ZUI_DIR" "$ASOUL_DIR" "$REFRESH_DIR" "$PROFILE_DIR" "$LOG_DIR"
    chmod 0775 "$DATA_ROOT" "$PERF_DIR" "$DONE_DIR" "$ZUI_DIR" "$ASOUL_DIR" "$REFRESH_DIR" "$PROFILE_DIR" "$LOG_DIR" 2>/dev/null
    copy_work_file "$SYSTEM_GAME_POLICY" "$DEFAULT_GAME_POLICY" "$WORK_GAME_POLICY" "game_policy"
    copy_work_file "$SYSTEM_PERF_CONFIG" "$DEFAULT_PERF_CONFIG" "$WORK_PERF_CONFIG" "performanceconfig"
    copy_if_missing "$DEFAULT_ASOPT" "$WORK_ASOPT"
    copy_if_missing "$DEFAULT_REFRESH_RULES" "$REFRESH_RULES"
    if [ ! -e "$APP_PROFILES" ]; then
        : > "$APP_PROFILES"
        chmod 0664 "$APP_PROFILES" 2>/dev/null
    fi
    grant_app_permissions
    start_app_service
    publish_state
    set_status "daemon=running" "last=init"
}

is_mounted_on() {
    target="$1"
    while read -r _ mount_point _; do
        if [ "$mount_point" = "$target" ]; then
            return 0
        fi
    done < /proc/mounts
    return 1
}

umount_if_needed() {
    target="$1"
    if is_mounted_on "$target"; then
        umount "$target" >> "$LOG_FILE" 2>&1
    fi
}

bind_file() {
    src="$1"
    dst="$2"
    name="$3"
    if [ ! -s "$src" ]; then
        log_line "$name source missing: $src"
        return 1
    fi
    if [ ! -e "$dst" ]; then
        log_line "$name target missing: $dst"
        return 1
    fi
    umount_if_needed "$dst"
    if mount -o bind "$src" "$dst" >> "$LOG_FILE" 2>&1; then
        log_line "$name bind ok: $src -> $dst"
        return 0
    fi
    log_line "$name bind failed: $src -> $dst"
    return 1
}

trigger_init_action() {
    prop="$1"
    value="$2"
    setprop "$prop" idle >> "$LOG_FILE" 2>&1
    sleep 1
    if setprop "$prop" "$value" >> "$LOG_FILE" 2>&1; then
        log_line "init action requested: $prop=$value"
        return 0
    fi
    log_line "init action request failed: $prop=$value"
    return 1
}

wait_mount_state() {
    expected="$1"
    shift
    tries=10
    while [ "$tries" -gt 0 ]; do
        ok=1
        for target in "$@"; do
            if [ "$expected" = "mounted" ]; then
                is_mounted_on "$target" || ok=0
            else
                is_mounted_on "$target" && ok=0
            fi
        done
        if [ "$ok" = "1" ]; then
            return 0
        fi
        tries=$((tries - 1))
        sleep 1
    done
    return 1
}

validate_zuipp_files() {
    if [ ! -s "$WORK_GAME_POLICY" ] || [ ! -s "$WORK_PERF_CONFIG" ]; then
        log_line "zuipp validate failed: missing work xml"
        return 1
    fi
    if ! grep -q "AppPolicy" "$WORK_GAME_POLICY"; then
        log_line "zuipp validate warning: game_policy has no AppPolicy text"
    fi
    if ! grep -q "PerformanceConfig" "$WORK_PERF_CONFIG"; then
        log_line "zuipp validate warning: performanceconfig has no PerformanceConfig text"
    fi
    return 0
}

restart_zuipp() {
    log_line "restart zuipp/gamehelper"
    force_stop_package com.zui.pp
    force_stop_package com.zui.game.service
    force_stop_package com.zui.gamehelper
    force_stop_package com.lenovo.legionzone
    set_status "daemon=running" "last=restart_zuipp"
}

force_stop_package() {
    pkg="$1"
    if pm path "$pkg" >/dev/null 2>&1; then
        am force-stop --user 0 "$pkg" >> "$LOG_FILE" 2>&1 ||
            log_line "force-stop failed: $pkg"
    fi
}

apply_zuipp() {
    validate_zuipp_files || {
        set_status "daemon=running" "last=apply_zuipp_failed"
        return 1
    }
    if trigger_init_action "$PROP_ZUIPP" apply &&
        wait_mount_state mounted "$SYSTEM_GAME_POLICY" "$SYSTEM_PERF_CONFIG"; then
        touch "$ZUI_ENABLED"
        chmod 0664 "$ZUI_ENABLED" 2>/dev/null
        restart_zuipp
        set_status "daemon=running" "last=apply_zuipp_ok"
        return 0
    fi
    log_line "zuipp init bind failed: prop=$(getprop "$PROP_ZUIPP" 2>/dev/null)"
    set_status "daemon=running" "last=apply_zuipp_failed"
    return 1
}

restore_zuipp() {
    trigger_init_action "$PROP_ZUIPP" restore
    wait_mount_state unmounted "$SYSTEM_GAME_POLICY" "$SYSTEM_PERF_CONFIG" ||
        log_line "zuipp init restore wait timeout"
    rm -f "$ZUI_ENABLED"
    restart_zuipp
    log_line "zuipp restore system xml"
    set_status "daemon=running" "last=restore_zuipp"
}

restart_asoul() {
    if trigger_init_action "$PROP_ASOUL" restart; then
        log_line "asoul restart requested through init"
        set_status "daemon=running" "last=restart_asoul"
        return 0
    fi
    log_line "asoul restart request failed"
    set_status "daemon=running" "last=restart_asoul_failed"
    return 1
}

apply_asoul() {
    if [ ! -s "$WORK_ASOPT" ]; then
        log_line "asoul config missing: $WORK_ASOPT"
        set_status "daemon=running" "last=apply_asoul_failed"
        return 1
    fi
    if ! trigger_init_action "$PROP_ASOUL" apply ||
        ! wait_mount_state mounted "$SYSTEM_ASOPT"; then
        log_line "asoul init bind failed: prop=$(getprop "$PROP_ASOUL" 2>/dev/null)"
        set_status "daemon=running" "last=apply_asoul_failed"
        return 1
    fi
    touch "$ASOUL_ENABLED"
    chmod 0664 "$ASOUL_ENABLED" 2>/dev/null
    set_status "daemon=running" "last=apply_asoul_ok"
}

restore_asoul() {
    trigger_init_action "$PROP_ASOUL" restore
    wait_mount_state unmounted "$SYSTEM_ASOPT" ||
        log_line "asoul init restore wait timeout"
    rm -f "$ASOUL_ENABLED"
    set_status "daemon=running" "last=restore_asoul"
}

set_refresh_rate() {
    rate="$1"
    case "$rate" in
        60|90|120|144) ;;
        *)
            log_line "invalid refresh rate: $rate"
            set_status "daemon=running" "last=set_refresh_failed" "rate=$rate"
            return 1
            ;;
    esac
    if settings put system peak_refresh_rate "$rate.0" >> "$LOG_FILE" 2>&1 &&
        settings put system min_refresh_rate "$rate.0" >> "$LOG_FILE" 2>&1; then
        LAST_REFRESH_RATE="$rate"
        log_line "refresh locked: $rate"
        set_status "daemon=running" "last=set_refresh_ok" "rate=$rate"
        return 0
    fi
    log_line "refresh lock failed: $rate"
    set_status "daemon=running" "last=set_refresh_failed" "rate=$rate"
    return 1
}

restore_refresh_rate() {
    settings delete system min_refresh_rate >> "$LOG_FILE" 2>&1
    settings delete system peak_refresh_rate >> "$LOG_FILE" 2>&1
    LAST_REFRESH_RATE=
    log_line "refresh restored to system default"
    set_status "daemon=running" "last=restore_refresh"
}

extract_pkg_from_focus() {
    line="$1"
    pkg="$(echo "$line" | sed -n 's/.* u[0-9][0-9]* \([^/ }]*\)\/.*/\1/p' | head -n 1)"
    if [ -z "$pkg" ]; then
        pkg="$(echo "$line" | sed -n 's/.* \([A-Za-z0-9_][A-Za-z0-9_.]*\)\/[A-Za-z0-9_.$]*.*/\1/p' | head -n 1)"
    fi
    echo "$pkg"
}

current_top_app() {
    line="$(dumpsys activity activities 2>/dev/null |
        grep -E 'topResumedActivity=|ResumedActivity:|mResumedActivity:' |
        head -n 1)"
    pkg="$(extract_pkg_from_focus "$line")"
    if [ -z "$pkg" ]; then
        line="$(dumpsys window 2>/dev/null | grep 'mFocusedApp=' | head -n 1)"
        pkg="$(extract_pkg_from_focus "$line")"
    fi
    if [ -z "$pkg" ]; then
        line="$(dumpsys window 2>/dev/null | grep 'mCurrentFocus=' | head -n 1)"
        pkg="$(extract_pkg_from_focus "$line")"
    fi
    echo "$pkg"
}

rule_for_app() {
    pkg="$1"
    if [ ! -s "$REFRESH_RULES" ]; then
        return 1
    fi
    while IFS='=' read -r key value; do
        case "$key" in
            ""|\#*) continue ;;
        esac
        if [ "$key" = "$pkg" ]; then
            echo "$value"
            return 0
        fi
    done < "$REFRESH_RULES"
    return 1
}

valid_package_name() {
    pkg="$1"
    case "$pkg" in
        ""|.*|*.) return 1 ;;
        *..*) return 1 ;;
        *[!A-Za-z0-9_.]*) return 1 ;;
    esac
    return 0
}

valid_refresh_rate() {
    case "$1" in
        60|90|120|144) return 0 ;;
    esac
    return 1
}

valid_flag() {
    case "$1" in
        0|1) return 0 ;;
    esac
    return 1
}

rewrite_rules_without_pkg() {
    pkg="$1"
    tmp="$REFRESH_RULES.tmp"
    mkdir -p "$REFRESH_DIR"
    : > "$tmp"
    if [ -s "$REFRESH_RULES" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            key="${line%%=*}"
            if [ "$key" = "$pkg" ]; then
                continue
            fi
            echo "$line" >> "$tmp"
        done < "$REFRESH_RULES"
    fi
    mv "$tmp" "$REFRESH_RULES"
    chmod 0664 "$REFRESH_RULES" 2>/dev/null
}

rewrite_profiles_without_pkg() {
    pkg="$1"
    tmp="$APP_PROFILES.tmp"
    mkdir -p "$PROFILE_DIR"
    : > "$tmp"
    if [ -s "$APP_PROFILES" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            key="$(printf '%s\n' "$line" | cut -d '|' -f 1)"
            if [ "$key" = "$pkg" ]; then
                continue
            fi
            echo "$line" >> "$tmp"
        done < "$APP_PROFILES"
    fi
    mv "$tmp" "$APP_PROFILES"
    chmod 0664 "$APP_PROFILES" 2>/dev/null
}

dedupe_profiles_file() {
    if [ ! -s "$APP_PROFILES" ]; then
        return 0
    fi
    tmp="$APP_PROFILES.dedupe"
    awk -F'|' '
        NF >= 5 && $1 != "" {
            if (!seen[$1]) {
                order[++n] = $1
            }
            seen[$1] = 1
            line[$1] = $0
        }
        END {
            for (i = 1; i <= n; i++) {
                print line[order[i]]
            }
        }
    ' "$APP_PROFILES" > "$tmp" 2>/dev/null || {
        rm -f "$tmp"
        return 1
    }
    mv "$tmp" "$APP_PROFILES"
    chmod 0664 "$APP_PROFILES" 2>/dev/null
}

set_refresh_rule() {
    pkg="$1"
    rate="$2"
    if ! valid_package_name "$pkg" || ! valid_refresh_rate "$rate"; then
        log_line "invalid refresh rule: pkg=$pkg rate=$rate"
        set_status "daemon=running" "last=set_refresh_rule_failed" "package=$pkg" "rate=$rate"
        return 1
    fi
    rewrite_rules_without_pkg "$pkg"
    echo "$pkg=$rate" >> "$REFRESH_RULES"
    chmod 0664 "$REFRESH_RULES" 2>/dev/null
    LAST_TOP_APP=
    publish_state
    log_line "refresh rule saved: $pkg -> $rate"
    set_status "daemon=running" "last=set_refresh_rule" "package=$pkg" "rate=$rate"
    if [ -f "$REFRESH_ENABLED" ]; then
        refresh_tick
    fi
}

remove_refresh_rule() {
    pkg="$1"
    if ! valid_package_name "$pkg"; then
        log_line "invalid refresh rule remove: pkg=$pkg"
        set_status "daemon=running" "last=remove_refresh_rule_failed" "package=$pkg"
        return 1
    fi
    rewrite_rules_without_pkg "$pkg"
    LAST_TOP_APP=
    publish_state
    log_line "refresh rule removed: $pkg"
    set_status "daemon=running" "last=remove_refresh_rule" "package=$pkg"
    if [ -f "$REFRESH_ENABLED" ]; then
        refresh_tick
    fi
}

set_app_profile() {
    pkg="$1"
    rate="$2"
    refresh="$3"
    zuipp="$4"
    asoul="$5"
    if ! valid_package_name "$pkg" || ! valid_refresh_rate "$rate" ||
        ! valid_flag "$refresh" || ! valid_flag "$zuipp" || ! valid_flag "$asoul"; then
        log_line "invalid app profile: pkg=$pkg rate=$rate refresh=$refresh zuipp=$zuipp asoul=$asoul"
        set_status "daemon=running" "last=set_app_profile_failed" "package=$pkg"
        return 1
    fi

    rewrite_profiles_without_pkg "$pkg"
    if [ "$refresh" = "1" ] || [ "$zuipp" = "1" ] || [ "$asoul" = "1" ]; then
        echo "$pkg|$rate|$refresh|$zuipp|$asoul" >> "$APP_PROFILES"
    fi
    chmod 0664 "$APP_PROFILES" 2>/dev/null
    dedupe_profiles_file

    if [ "$refresh" = "1" ]; then
        rewrite_rules_without_pkg "$pkg"
        echo "$pkg=$rate" >> "$REFRESH_RULES"
        chmod 0664 "$REFRESH_RULES" 2>/dev/null
    else
        rewrite_rules_without_pkg "$pkg"
    fi

    LAST_TOP_APP=
    publish_state
    log_line "app profile saved: $pkg rate=$rate refresh=$refresh zuipp=$zuipp asoul=$asoul"
    set_status "daemon=running" "last=set_app_profile" "package=$pkg" "rate=$rate" "refresh=$refresh" "zuipp=$zuipp" "asoul=$asoul"
    if [ -f "$REFRESH_ENABLED" ]; then
        refresh_tick
    fi
}

remove_app_profile() {
    pkg="$1"
    if ! valid_package_name "$pkg"; then
        log_line "invalid app profile remove: pkg=$pkg"
        set_status "daemon=running" "last=remove_app_profile_failed" "package=$pkg"
        return 1
    fi
    rewrite_profiles_without_pkg "$pkg"
    rewrite_rules_without_pkg "$pkg"
    LAST_TOP_APP=
    publish_state
    log_line "app profile removed: $pkg"
    set_status "daemon=running" "last=remove_app_profile" "package=$pkg"
    if [ -f "$REFRESH_ENABLED" ]; then
        refresh_tick
    fi
}

refresh_tick() {
    if [ ! -f "$REFRESH_ENABLED" ]; then
        return 0
    fi
    top="$(current_top_app)"
    if [ -z "$top" ]; then
        EMPTY_TOP_TICKS=$((EMPTY_TOP_TICKS + 1))
        if [ "$EMPTY_TOP_TICKS" -ge 3 ] && [ -n "$LAST_REFRESH_RATE" ]; then
            log_line "top app unavailable, restore refresh after $EMPTY_TOP_TICKS checks"
            LAST_TOP_APP=
            restore_refresh_rate
        fi
        return 0
    fi
    EMPTY_TOP_TICKS=0
    if [ "$top" = "$LAST_TOP_APP" ]; then
        return 0
    fi
    LAST_TOP_APP="$top"
    rate="$(rule_for_app "$top")"
    if [ -z "$rate" ]; then
        base="${top%%:*}"
        if [ "$base" != "$top" ]; then
            rate="$(rule_for_app "$base")"
        fi
    fi
    if [ -n "$rate" ]; then
        log_line "top app matched refresh rule: $top -> $rate"
        set_refresh_rate "$rate"
    elif [ -n "$LAST_REFRESH_RATE" ]; then
        log_line "top app no rule, restore refresh: $top"
        restore_refresh_rate
    fi
}

prop_value() {
    key="$1"
    file="$2"
    sed -n "s/^$key=//p" "$file" 2>/dev/null | tail -n 1
}

archive_request() {
    file="$1"
    base="$(basename "$file")"
    stamp="$(date '+%Y%m%d_%H%M%S')"
    mkdir -p "$DONE_DIR"
    mv "$file" "$DONE_DIR/$stamp.$base" 2>/dev/null
}

handle_request() {
    source="$1"
    cmd="$2"
    rate="$3"
    pkg="$4"
    profile_refresh="$5"
    profile_zuipp="$6"
    profile_asoul="$7"
    log_line "request: $source cmd=$cmd rate=$rate pkg=$pkg refresh=$profile_refresh zuipp=$profile_zuipp asoul=$profile_asoul"

    case "$cmd" in
        apply_zuipp) apply_zuipp ;;
        restore_zuipp) restore_zuipp ;;
        restart_zuipp) restart_zuipp ;;
        apply_asoul) apply_asoul ;;
        restore_asoul) restore_asoul ;;
        restart_asoul) restart_asoul ;;
        set_refresh) set_refresh_rate "$rate" ;;
        restore_refresh) restore_refresh_rate ;;
        set_refresh_rule) set_refresh_rule "$pkg" "$rate" ;;
        remove_refresh_rule) remove_refresh_rule "$pkg" ;;
        set_app_profile) set_app_profile "$pkg" "$rate" "$profile_refresh" "$profile_zuipp" "$profile_asoul" ;;
        remove_app_profile) remove_app_profile "$pkg" ;;
        enable_auto_refresh)
            touch "$REFRESH_ENABLED"
            chmod 0664 "$REFRESH_ENABLED" 2>/dev/null
            LAST_TOP_APP=
            publish_state
            set_status "daemon=running" "last=enable_auto_refresh"
            refresh_tick
            ;;
        disable_auto_refresh)
            rm -f "$REFRESH_ENABLED"
            restore_refresh_rate
            publish_state
            set_status "daemon=running" "last=disable_auto_refresh"
            ;;
        status)
            publish_state
            set_status "daemon=running" "last=status"
            ;;
        *)
            log_line "unknown request cmd: $cmd"
            set_status "daemon=running" "last=unknown_request" "cmd=$cmd"
            ;;
    esac
}

process_request_file() {
    file="$1"
    if [ ! -s "$file" ]; then
        return 0
    fi
    cmd="$(prop_value cmd "$file")"
    rate="$(prop_value rate "$file")"
    pkg="$(prop_value package "$file")"
    profile_refresh="$(prop_value refresh "$file")"
    profile_zuipp="$(prop_value zuipp "$file")"
    profile_asoul="$(prop_value asoul "$file")"
    handle_request "$file" "$cmd" "$rate" "$pkg" "$profile_refresh" "$profile_zuipp" "$profile_asoul"
    archive_request "$file"
}

process_settings_request() {
    id="$(settings_get_clean "$REQ_ID_KEY")"
    if [ -z "$id" ] || [ "$id" = "$LAST_SETTINGS_REQUEST_ID" ]; then
        return 0
    fi
    if [ -s "$LAST_SETTINGS_ID_FILE" ] && [ "$id" = "$(cat "$LAST_SETTINGS_ID_FILE" 2>/dev/null)" ]; then
        LAST_SETTINGS_REQUEST_ID="$id"
        return 0
    fi
    LAST_SETTINGS_REQUEST_ID="$id"
    cmd="$(settings_get_clean "$REQ_CMD_KEY")"
    rate="$(settings_get_clean "$REQ_RATE_KEY")"
    pkg="$(settings_get_clean "$REQ_PACKAGE_KEY")"
    profile_refresh="$(settings_get_clean "$REQ_PROFILE_REFRESH_KEY")"
    profile_zuipp="$(settings_get_clean "$REQ_PROFILE_ZUIPP_KEY")"
    profile_asoul="$(settings_get_clean "$REQ_PROFILE_ASOUL_KEY")"
    handle_request "settings:$id" "$cmd" "$rate" "$pkg" "$profile_refresh" "$profile_zuipp" "$profile_asoul"
    echo "$id" > "$LAST_SETTINGS_ID_FILE"
    chmod 0664 "$LAST_SETTINGS_ID_FILE" 2>/dev/null
    settings_delete_quiet "$REQ_CMD_KEY"
    settings_delete_quiet "$REQ_RATE_KEY"
    settings_delete_quiet "$REQ_PACKAGE_KEY"
    settings_delete_quiet "$REQ_PROFILE_REFRESH_KEY"
    settings_delete_quiet "$REQ_PROFILE_ZUIPP_KEY"
    settings_delete_quiet "$REQ_PROFILE_ASOUL_KEY"
}

process_atomic_settings_request() {
    request="$(settings_get_clean "$REQ_TEXT_KEY")"
    if [ -z "$request" ] || [ "$request" = "$LAST_SETTINGS_REQUEST_TEXT" ]; then
        return 0
    fi
    if [ -s "$LAST_SETTINGS_TEXT_FILE" ] &&
        [ "$request" = "$(cat "$LAST_SETTINGS_TEXT_FILE" 2>/dev/null)" ]; then
        LAST_SETTINGS_REQUEST_TEXT="$request"
        return 0
    fi

    field_count="$(printf '%s\n' "$request" | awk -F'|' '{print NF}')"
    LAST_SETTINGS_REQUEST_TEXT="$request"
    echo "$request" > "$LAST_SETTINGS_TEXT_FILE"
    chmod 0664 "$LAST_SETTINGS_TEXT_FILE" 2>/dev/null
    if [ "$field_count" -ne 7 ]; then
        log_line "invalid atomic settings request: fields=$field_count"
        return 1
    fi

    id="$(printf '%s\n' "$request" | cut -d '|' -f 1)"
    cmd="$(printf '%s\n' "$request" | cut -d '|' -f 2)"
    rate="$(printf '%s\n' "$request" | cut -d '|' -f 3)"
    pkg="$(printf '%s\n' "$request" | cut -d '|' -f 4)"
    profile_refresh="$(printf '%s\n' "$request" | cut -d '|' -f 5)"
    profile_zuipp="$(printf '%s\n' "$request" | cut -d '|' -f 6)"
    profile_asoul="$(printf '%s\n' "$request" | cut -d '|' -f 7)"
    if [ -z "$id" ] || [ -z "$cmd" ]; then
        log_line "invalid atomic settings request: empty id or cmd"
        return 1
    fi
    handle_request "settings-atomic:$id" "$cmd" "$rate" "$pkg" \
        "$profile_refresh" "$profile_zuipp" "$profile_asoul"
}

boot_restore() {
    if [ -f "$ZUI_ENABLED" ]; then
        log_line "boot apply enabled zuipp bind"
        apply_zuipp
    fi
    if [ -f "$ASOUL_ENABLED" ]; then
        log_line "boot apply enabled asoul bind"
        apply_asoul
    fi
}

init_settings_request_state() {
    id="$(settings_get_clean "$REQ_ID_KEY")"
    if [ -n "$id" ] && [ ! -s "$LAST_SETTINGS_ID_FILE" ]; then
        echo "$id" > "$LAST_SETTINGS_ID_FILE"
        chmod 0664 "$LAST_SETTINGS_ID_FILE" 2>/dev/null
        LAST_SETTINGS_REQUEST_ID="$id"
        log_line "ignore stale settings request at boot: $id"
    elif [ -s "$LAST_SETTINGS_ID_FILE" ]; then
        LAST_SETTINGS_REQUEST_ID="$(cat "$LAST_SETTINGS_ID_FILE" 2>/dev/null)"
    fi
}

init_atomic_settings_request_state() {
    request="$(settings_get_clean "$REQ_TEXT_KEY")"
    if [ -n "$request" ] && [ ! -s "$LAST_SETTINGS_TEXT_FILE" ]; then
        echo "$request" > "$LAST_SETTINGS_TEXT_FILE"
        chmod 0664 "$LAST_SETTINGS_TEXT_FILE" 2>/dev/null
        LAST_SETTINGS_REQUEST_TEXT="$request"
        log_line "ignore stale atomic settings request at boot"
    elif [ -s "$LAST_SETTINGS_TEXT_FILE" ]; then
        LAST_SETTINGS_REQUEST_TEXT="$(cat "$LAST_SETTINGS_TEXT_FILE" 2>/dev/null)"
    fi
}

main_loop() {
    init_dirs
    log_line "zui_perfctld start"
    init_atomic_settings_request_state
    init_settings_request_state
    boot_restore
    while true; do
        process_atomic_settings_request
        process_settings_request
        process_request_file "$ADB_REQUEST"
        refresh_tick
        sleep 1
    done
}

main_loop
