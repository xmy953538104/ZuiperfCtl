#!/system/bin/sh

DATA_ROOT=/data/local/tmp/zui_perfctl
CONTROL_DIR=$DATA_ROOT/perfctl
DONE_DIR=$CONTROL_DIR/processed
ZUI_DIR=$DATA_ROOT/zuipp
ASOUL_DIR=$DATA_ROOT/asoul
REFRESH_DIR=$DATA_ROOT/refresh
PERFORMANCE_DIR=$DATA_ROOT/performance
LOG_DIR=$DATA_ROOT/log

LOG_FILE=$LOG_DIR/perfctld.log
ASOUL_LOG=$LOG_DIR/asoulopt.log
STATUS_FILE=$CONTROL_DIR/status.prop
ADB_REQUEST=$CONTROL_DIR/request.prop
LAST_REQUEST_FILE=$CONTROL_DIR/last_settings_request_text

APP_PACKAGE=com.zui.zuiperfctl
APP_SERVICE_COMPONENT=com.zui.zuiperfctl/com.zui.perfctl.PerfCtlQuickService
PROP_ZUIPP=zui_perfctl.zuipp
PROP_ASOUL=zui_perfctl.asoul

SYSTEM_GAME_POLICY=/system/etc/game_policy.xml
SYSTEM_PERF_CONFIG=/system/etc/performanceconfig.xml
SYSTEM_ASOPT=/system/etc/asopt.conf
DEFAULT_GAME_POLICY=/system/etc/zui_perfctl/default_game_policy.xml
DEFAULT_PERF_CONFIG=/system/etc/zui_perfctl/default_performanceconfig.xml
DEFAULT_ASOPT=/system/etc/zui_perfctl/default_asopt.conf

WORK_GAME_POLICY=$ZUI_DIR/game_policy.xml
WORK_PERF_CONFIG=$ZUI_DIR/performanceconfig.xml
WORK_ASOPT=$ASOUL_DIR/asopt.conf
REFRESH_RULES=$REFRESH_DIR/rules.prop
PERFORMANCE_PROFILES=$PERFORMANCE_DIR/profiles.prop
PERFORMANCE_SUMMARY=$PERFORMANCE_DIR/summary.txt
ZUI_ENABLED=$ZUI_DIR/enabled.flag
ASOUL_ENABLED=$ASOUL_DIR/enabled.flag

REQ_TEXT_KEY=zui_perfctl_request_text
STATUS_TIME_KEY=zui_perfctl_status_time
STATUS_LAST_KEY=zui_perfctl_status_last
STATUS_TEXT_KEY=zui_perfctl_status_text
RULES_TEXT_KEY=zui_perfctl_refresh_rules_text
PERFORMANCE_PROFILES_KEY=zui_perfctl_performance_profiles_text
PERFORMANCE_SUMMARY_KEY=zui_perfctl_performance_summary
TOP_PACKAGE_KEY=zui_perfctl_top_package
ASOUL_HEALTH_KEY=zui_perfctl_asoul_health
XML_STATE_KEY=zui_perfctl_xml_state
LOG_EXPORT_KEY=zui_perfctl_log_export

BASE_REFRESH_RATE=120
LAST_TOP_APP=
LAST_USER_APP=
LAST_USER_APP_TIME=0
LAST_REFRESH_RATE=
LAST_SETTINGS_REQUEST_TEXT=
EMPTY_TOP_TICKS=0
HEALTH_TICKS=0
LOOP_TICKS=0
NO_RULE_TOP_TICKS=0

ts() {
    date '+%Y-%m-%d %H:%M:%S'
}

now_seconds() {
    date '+%s'
}

settings_get_clean() {
    value="$(settings get system "$1" 2>/dev/null)"
    if [ "$value" = "null" ]; then
        value=
    fi
    printf '%s\n' "$value"
}

settings_put_quiet() {
    settings put system "$1" "$2" >/dev/null 2>&1
}

log_line() {
    mkdir -p "$LOG_DIR"
    printf '%s %s\n' "$(ts)" "$*" >> "$LOG_FILE"
}

trim_log() {
    [ -s "$LOG_FILE" ] || return 0
    size="$(wc -c < "$LOG_FILE" 2>/dev/null)"
    if [ "${size:-0}" -gt 524288 ]; then
        tail -n 2000 "$LOG_FILE" > "$LOG_FILE.tmp" 2>/dev/null &&
            mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
}

set_status() {
    mkdir -p "$CONTROL_DIR"
    {
        echo "time=$(ts)"
        for line in "$@"; do
            echo "$line"
        done
    } > "$STATUS_FILE"
    chmod 0664 "$STATUS_FILE" 2>/dev/null

    last=
    for line in "$@"; do
        case "$line" in
            last=*) last="${line#last=}" ;;
        esac
    done
    settings_put_quiet "$STATUS_TIME_KEY" "$(ts)"
    settings_put_quiet "$STATUS_LAST_KEY" "$last"
    status_text="$(tr '\n' ';' < "$STATUS_FILE" 2>/dev/null)"
    settings_put_quiet "$STATUS_TEXT_KEY" "$status_text"
}

copy_if_missing() {
    src="$1"
    dst="$2"
    if [ -s "$dst" ]; then
        return 0
    fi
    if [ -s "$src" ]; then
        cp "$src" "$dst" && chmod 0664 "$dst"
    fi
}

copy_work_file() {
    live="$1"
    fallback="$2"
    dst="$3"
    name="$4"
    if [ -s "$dst" ]; then
        return 0
    fi
    if [ -s "$live" ]; then
        cp "$live" "$dst" && chmod 0664 "$dst"
        log_line "$name initialized from live system file"
    else
        copy_if_missing "$fallback" "$dst"
        log_line "$name initialized from payload default"
    fi
}

valid_package_name() {
    pkg="$1"
    case "$pkg" in
        ""|.*|*.) return 1 ;;
        *..*) return 1 ;;
        *[!A-Za-z0-9_.]*) return 1 ;;
    esac
    return 0
}

valid_refresh_rate() {
    case "$1" in
        60|90|120|144) return 0 ;;
    esac
    return 1
}

valid_mode() {
    case "$1" in
        balanced|powersave|savage) return 0 ;;
    esac
    return 1
}

valid_positive_int() {
    case "$1" in
        ""|*[!0-9]*) return 1 ;;
    esac
    [ "$1" -gt 0 ]
}

rewrite_rules_without_pkg() {
    pkg="$1"
    tmp="$REFRESH_RULES.tmp"
    : > "$tmp"
    if [ -s "$REFRESH_RULES" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            key="${line%%=*}"
            [ "$key" = "$pkg" ] && continue
            echo "$line" >> "$tmp"
        done < "$REFRESH_RULES"
    fi
    mv "$tmp" "$REFRESH_RULES"
    chmod 0664 "$REFRESH_RULES" 2>/dev/null
}

rewrite_performance_without_key() {
    pkg="$1"
    mode="$2"
    tmp="$PERFORMANCE_PROFILES.tmp"
    : > "$tmp"
    if [ -s "$PERFORMANCE_PROFILES" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            line_pkg="$(printf '%s\n' "$line" | cut -d '|' -f 1)"
            line_mode="$(printf '%s\n' "$line" | cut -d '|' -f 2)"
            if [ "$line_pkg" = "$pkg" ] && [ "$line_mode" = "$mode" ]; then
                continue
            fi
            echo "$line" >> "$tmp"
        done < "$PERFORMANCE_PROFILES"
    fi
    mv "$tmp" "$PERFORMANCE_PROFILES"
    chmod 0664 "$PERFORMANCE_PROFILES" 2>/dev/null
}

migrate_refresh_rules() {
    tmp="$REFRESH_RULES.migrate"
    : > "$tmp"
    if [ -s "$REFRESH_RULES" ]; then
        while IFS='=' read -r pkg rate; do
            valid_package_name "$pkg" || continue
            valid_refresh_rate "$rate" || continue
            [ "$rate" = "$BASE_REFRESH_RATE" ] && continue
            printf '%s=%s\n' "$pkg" "$rate" >> "$tmp"
        done < "$REFRESH_RULES"
    fi
    mv "$tmp" "$REFRESH_RULES"
    chmod 0664 "$REFRESH_RULES" 2>/dev/null
}

publish_refresh_state() {
    rules_text=
    if [ -s "$REFRESH_RULES" ]; then
        rules_text="$(grep -v '^[[:space:]]*#' "$REFRESH_RULES" 2>/dev/null |
            grep -v '^[[:space:]]*$' 2>/dev/null)"
    fi
    settings_put_quiet "$RULES_TEXT_KEY" "$rules_text"
}

publish_performance_state() {
    profiles_text=
    if [ -s "$PERFORMANCE_PROFILES" ]; then
        profiles_text="$(grep -v '^[[:space:]]*#' "$PERFORMANCE_PROFILES" 2>/dev/null |
            grep -v '^[[:space:]]*$' 2>/dev/null)"
    fi
    settings_put_quiet "$PERFORMANCE_PROFILES_KEY" "$profiles_text"
    summary=
    [ -s "$PERFORMANCE_SUMMARY" ] && summary="$(cat "$PERFORMANCE_SUMMARY" 2>/dev/null)"
    settings_put_quiet "$PERFORMANCE_SUMMARY_KEY" "$summary"
}

clear_performance_summary() {
    rm -f "$PERFORMANCE_SUMMARY" "$PERFORMANCE_SUMMARY.tmp"
    settings_put_quiet "$PERFORMANCE_SUMMARY_KEY" ""
}

is_mounted_on() {
    target="$1"
    while read -r _ mount_point _; do
        [ "$mount_point" = "$target" ] && return 0
    done < /proc/mounts
    return 1
}

publish_xml_state() {
    if is_mounted_on "$SYSTEM_GAME_POLICY" && is_mounted_on "$SYSTEM_PERF_CONFIG"; then
        settings_put_quiet "$XML_STATE_KEY" "已挂载，工作 XML 正在生效"
    else
        settings_put_quiet "$XML_STATE_KEY" "未挂载，当前使用官方 XML"
    fi
}

publish_asoul_health() {
    service_state="$(getprop init.svc.zui_asoulopt 2>/dev/null)"
    pid="$(pidof AsoulOpt 2>/dev/null | awk '{print $1}')"
    domain=
    if [ -n "$pid" ]; then
        domain="$(ps -AZ 2>/dev/null | awk -v wanted="$pid" '$3 == wanted {print $1; exit}')"
    fi
    log_size=0
    [ -f "$ASOUL_LOG" ] && log_size="$(wc -c < "$ASOUL_LOG" 2>/dev/null)"
    health="服务：${service_state:-unknown}
进程：${pid:-未运行}
SELinux：${domain:-未识别}
日志：${log_size:-0} 字节"
    settings_put_quiet "$ASOUL_HEALTH_KEY" "$health"
}

publish_state() {
    publish_refresh_state
    publish_performance_state
    publish_xml_state
    publish_asoul_health
}

grant_app_permissions() {
    pm grant "$APP_PACKAGE" android.permission.POST_NOTIFICATIONS >/dev/null 2>&1
    appops set "$APP_PACKAGE" POST_NOTIFICATION allow >/dev/null 2>&1
    appops set "$APP_PACKAGE" WRITE_SETTINGS allow >/dev/null 2>&1
}

notify_quick_service() {
    am start-foreground-service \
        -a com.zui.zuiperfctl.action.REFRESH_NOTIFICATION \
        -n "$APP_SERVICE_COMPONENT" >/dev/null 2>&1 ||
        am startservice -n "$APP_SERVICE_COMPONENT" >/dev/null 2>&1
}

init_dirs() {
    mkdir -p "$CONTROL_DIR" "$DONE_DIR" "$ZUI_DIR" "$ASOUL_DIR" \
        "$REFRESH_DIR" "$PERFORMANCE_DIR" "$LOG_DIR"
    chmod 0775 "$DATA_ROOT" "$CONTROL_DIR" "$DONE_DIR" "$ZUI_DIR" "$ASOUL_DIR" \
        "$REFRESH_DIR" "$PERFORMANCE_DIR" "$LOG_DIR" 2>/dev/null
    copy_work_file "$SYSTEM_GAME_POLICY" "$DEFAULT_GAME_POLICY" \
        "$WORK_GAME_POLICY" "game_policy"
    copy_work_file "$SYSTEM_PERF_CONFIG" "$DEFAULT_PERF_CONFIG" \
        "$WORK_PERF_CONFIG" "performanceconfig"
    copy_if_missing "$DEFAULT_ASOPT" "$WORK_ASOPT"
    [ -e "$REFRESH_RULES" ] || : > "$REFRESH_RULES"
    [ -e "$PERFORMANCE_PROFILES" ] || : > "$PERFORMANCE_PROFILES"
    chmod 0664 "$REFRESH_RULES" "$PERFORMANCE_PROFILES" 2>/dev/null
    migrate_refresh_rules
    rm -f "$REFRESH_DIR/enabled.flag"
    grant_app_permissions
}

trigger_init_action() {
    prop="$1"
    value="$2"
    setprop "$prop" idle >> "$LOG_FILE" 2>&1
    sleep 1
    if setprop "$prop" "$value" >> "$LOG_FILE" 2>&1; then
        log_line "init action requested: $prop=$value"
        return 0
    fi
    log_line "init action request failed: $prop=$value"
    return 1
}

wait_mount_state() {
    expected="$1"
    shift
    tries=10
    while [ "$tries" -gt 0 ]; do
        ok=1
        for target in "$@"; do
            if [ "$expected" = "mounted" ]; then
                is_mounted_on "$target" || ok=0
            else
                is_mounted_on "$target" && ok=0
            fi
        done
        [ "$ok" = "1" ] && return 0
        tries=$((tries - 1))
        sleep 1
    done
    return 1
}

force_stop_package() {
    pkg="$1"
    if pm path "$pkg" >/dev/null 2>&1; then
        am force-stop --user 0 "$pkg" >> "$LOG_FILE" 2>&1 ||
            log_line "force-stop failed: $pkg"
    fi
}

restart_zuipp() {
    log_line "restart ZuiPP and game services"
    force_stop_package com.zui.pp
    force_stop_package com.zui.game.service
    force_stop_package com.zui.gamehelper
    force_stop_package com.lenovo.legionzone
}

validate_zuipp_files() {
    if [ ! -s "$WORK_GAME_POLICY" ] || [ ! -s "$WORK_PERF_CONFIG" ]; then
        log_line "ZuiPP XML validation failed: missing work file"
        return 1
    fi
    grep -q "AppPolicy" "$WORK_GAME_POLICY" 2>/dev/null || {
        log_line "ZuiPP XML validation failed: AppPolicy missing"
        return 1
    }
    grep -q "GameLimitConfig" "$WORK_PERF_CONFIG" 2>/dev/null || {
        log_line "ZuiPP XML validation failed: GameLimitConfig missing"
        return 1
    }
    return 0
}

apply_zuipp() {
    validate_zuipp_files || {
        set_status "daemon=running" "last=apply_zuipp_failed"
        return 1
    }
    if trigger_init_action "$PROP_ZUIPP" apply &&
        wait_mount_state mounted "$SYSTEM_GAME_POLICY" "$SYSTEM_PERF_CONFIG"; then
        touch "$ZUI_ENABLED"
        chmod 0664 "$ZUI_ENABLED" 2>/dev/null
        restart_zuipp
        publish_xml_state
        set_status "daemon=running" "last=apply_zuipp_ok"
        return 0
    fi
    log_line "ZuiPP bind failed: prop=$(getprop "$PROP_ZUIPP" 2>/dev/null)"
    publish_xml_state
    set_status "daemon=running" "last=apply_zuipp_failed"
    return 1
}

restore_zuipp() {
    trigger_init_action "$PROP_ZUIPP" restore
    wait_mount_state unmounted "$SYSTEM_GAME_POLICY" "$SYSTEM_PERF_CONFIG" ||
        log_line "ZuiPP restore wait timeout"
    rm -f "$ZUI_ENABLED"
    restart_zuipp
    publish_xml_state
    set_status "daemon=running" "last=restore_zuipp"
}

restart_asoul() {
    if trigger_init_action "$PROP_ASOUL" restart; then
        log_line "AsoulOpt restart requested"
        sleep 1
        publish_asoul_health
        set_status "daemon=running" "last=restart_asoul"
        return 0
    fi
    set_status "daemon=running" "last=restart_asoul_failed"
    return 1
}

apply_asoul() {
    [ -s "$WORK_ASOPT" ] || return 1
    if trigger_init_action "$PROP_ASOUL" apply &&
        wait_mount_state mounted "$SYSTEM_ASOPT"; then
        touch "$ASOUL_ENABLED"
        chmod 0664 "$ASOUL_ENABLED" 2>/dev/null
        publish_asoul_health
        return 0
    fi
    return 1
}

restore_asoul() {
    trigger_init_action "$PROP_ASOUL" restore
    wait_mount_state unmounted "$SYSTEM_ASOPT" || true
    rm -f "$ASOUL_ENABLED"
    publish_asoul_health
}

set_refresh_rate() {
    rate="$1"
    valid_refresh_rate "$rate" || {
        log_line "invalid refresh rate: $rate"
        set_status "daemon=running" "last=set_refresh_failed" "rate=$rate"
        return 1
    }
    peak="$(settings_get_clean peak_refresh_rate)"
    min="$(settings_get_clean min_refresh_rate)"
    if [ "$peak" = "$rate.0" ] && [ "$min" = "$rate.0" ]; then
        LAST_REFRESH_RATE="$rate"
        return 0
    fi
    if settings put system peak_refresh_rate "$rate.0" >> "$LOG_FILE" 2>&1 &&
        settings put system min_refresh_rate "$rate.0" >> "$LOG_FILE" 2>&1; then
        LAST_REFRESH_RATE="$rate"
        log_line "refresh locked: $rate"
        return 0
    fi
    log_line "refresh lock failed: $rate"
    return 1
}

restore_refresh_rate() {
    set_refresh_rate "$BASE_REFRESH_RATE"
    set_status "daemon=running" "last=restore_refresh" "rate=$BASE_REFRESH_RATE"
}

extract_pkg_from_focus() {
    line="$1"
    pkg="$(echo "$line" | sed -n 's/.* u[0-9][0-9]* \([^/ }]*\)\/.*/\1/p' | head -n 1)"
    if [ -z "$pkg" ]; then
        pkg="$(echo "$line" |
            sed -n 's/.* \([A-Za-z0-9_][A-Za-z0-9_.]*\)\/[A-Za-z0-9_.$]*.*/\1/p' |
            head -n 1)"
    fi
    printf '%s\n' "$pkg"
}

current_top_app() {
    line="$(dumpsys activity activities 2>/dev/null |
        grep -E 'topResumedActivity=|ResumedActivity:|mResumedActivity:' |
        head -n 1)"
    pkg="$(extract_pkg_from_focus "$line")"
    if [ -z "$pkg" ]; then
        line="$(dumpsys window 2>/dev/null | grep 'mFocusedApp=' | head -n 1)"
        pkg="$(extract_pkg_from_focus "$line")"
    fi
    if [ -z "$pkg" ]; then
        line="$(dumpsys window 2>/dev/null | grep 'mCurrentFocus=' | head -n 1)"
        pkg="$(extract_pkg_from_focus "$line")"
    fi
    printf '%s\n' "$pkg"
}

is_overlay_package() {
    case "$1" in
        com.android.systemui) return 0 ;;
    esac
    return 1
}

is_non_target_package() {
    case "$1" in
        "$APP_PACKAGE"|com.zui.launcher|com.android.launcher3) return 0 ;;
    esac
    return 1
}

remember_user_app() {
    pkg="$1"
    valid_package_name "$pkg" || return 1
    LAST_USER_APP="$pkg"
    LAST_USER_APP_TIME="$(now_seconds)"
}

recent_last_user_app() {
    valid_package_name "$LAST_USER_APP" || return 1
    now="$(now_seconds)"
    age=$((now - LAST_USER_APP_TIME))
    [ "$age" -ge 0 ] && [ "$age" -le 15 ]
}

rule_for_app() {
    pkg="$1"
    [ -s "$REFRESH_RULES" ] || return 1
    while IFS='=' read -r key value; do
        [ "$key" = "$pkg" ] || continue
        printf '%s\n' "$value"
        return 0
    done < "$REFRESH_RULES"
    return 1
}

set_refresh_rule() {
    pkg="$1"
    rate="$2"
    valid_package_name "$pkg" && valid_refresh_rate "$rate" || return 1
    rewrite_rules_without_pkg "$pkg"
    if [ "$rate" != "$BASE_REFRESH_RATE" ]; then
        printf '%s=%s\n' "$pkg" "$rate" >> "$REFRESH_RULES"
    fi
    chmod 0664 "$REFRESH_RULES" 2>/dev/null
    publish_refresh_state
}

remove_refresh_rule() {
    pkg="$1"
    valid_package_name "$pkg" || return 1
    rewrite_rules_without_pkg "$pkg"
    LAST_TOP_APP=
    publish_refresh_state
    refresh_tick
    set_status "daemon=running" "last=remove_refresh_rule" "package=$pkg"
}

learn_refresh() {
    rate="$1"
    valid_refresh_rate "$rate" || {
        set_status "daemon=running" "last=learn_refresh_failed" "rate=$rate"
        return 1
    }
    top="$(current_top_app)"
    if [ -z "$top" ] || is_overlay_package "$top" || [ "$top" = "$APP_PACKAGE" ]; then
        if recent_last_user_app; then
            top="$LAST_USER_APP"
        else
            top=
        fi
    elif is_non_target_package "$top"; then
        top=
    fi
    if ! valid_package_name "$top"; then
        if [ "$rate" = "$BASE_REFRESH_RATE" ]; then
            set_refresh_rate "$rate" || return 1
            log_line "refresh restored without learnable foreground app"
            set_status "daemon=running" "last=learn_refresh_global" "rate=$rate"
            notify_quick_service
            return 0
        fi
        log_line "learn refresh ignored without learnable foreground app: $rate"
        set_status "daemon=running" "last=learn_refresh_no_target" "rate=$rate"
        notify_quick_service
        return 1
    fi
    set_refresh_rate "$rate" || return 1
    remember_user_app "$top"
    LAST_TOP_APP="$top"
    settings_put_quiet "$TOP_PACKAGE_KEY" "$top"
    set_refresh_rule "$top" "$rate"
    log_line "learned refresh: $top -> $rate"
    set_status "daemon=running" "last=learn_refresh" "package=$top" "rate=$rate"
    notify_quick_service
}

refresh_tick() {
    if [ ! -s "$REFRESH_RULES" ]; then
        set_refresh_rate "$BASE_REFRESH_RATE"
        NO_RULE_TOP_TICKS=$((NO_RULE_TOP_TICKS + 1))
        if [ "$NO_RULE_TOP_TICKS" -lt 5 ]; then
            return 0
        fi
        NO_RULE_TOP_TICKS=0
    else
        NO_RULE_TOP_TICKS=0
    fi
    top="$(current_top_app)"
    if [ -z "$top" ]; then
        EMPTY_TOP_TICKS=$((EMPTY_TOP_TICKS + 1))
        if [ "$EMPTY_TOP_TICKS" -ge 3 ]; then
            set_refresh_rate "$BASE_REFRESH_RATE"
        fi
        return 0
    fi
    EMPTY_TOP_TICKS=0
    if is_overlay_package "$top"; then
        if recent_last_user_app; then
            top="$LAST_USER_APP"
        else
            top=
        fi
    elif ! is_non_target_package "$top"; then
        remember_user_app "$top"
    fi
    [ -n "$top" ] || return 0
    if [ "$top" = "$LAST_TOP_APP" ]; then
        return 0
    fi
    LAST_TOP_APP="$top"
    settings_put_quiet "$TOP_PACKAGE_KEY" "$top"
    rate="$(rule_for_app "$top")"
    [ -n "$rate" ] || rate="$BASE_REFRESH_RATE"
    set_refresh_rate "$rate"
    log_line "foreground refresh: $top -> $rate"
    notify_quick_service
}

set_performance_profile() {
    pkg="$1"
    mode="$2"
    little_max="$3"
    little_min="$4"
    big_max="$5"
    big_min="$6"
    titan_max="$7"
    titan_min="$8"
    mega_max="$9"
    shift 9
    mega_min="$1"
    gpu_max="$2"
    gpu_min="$3"
    if ! valid_package_name "$pkg" || ! valid_mode "$mode" ||
        ! valid_positive_int "$little_max" || ! valid_positive_int "$little_min" ||
        ! valid_positive_int "$big_max" || ! valid_positive_int "$big_min" ||
        ! valid_positive_int "$titan_max" || ! valid_positive_int "$titan_min" ||
        ! valid_positive_int "$mega_max" || ! valid_positive_int "$mega_min" ||
        ! valid_positive_int "$gpu_max" || ! valid_positive_int "$gpu_min" ||
        [ "$little_max" -lt "$little_min" ] ||
        [ "$big_max" -lt "$big_min" ] ||
        [ "$titan_max" -lt "$titan_min" ] ||
        [ "$mega_max" -lt "$mega_min" ] ||
        [ "$gpu_max" -lt "$gpu_min" ]; then
        log_line "invalid performance profile: $pkg $mode"
        set_status "daemon=running" "last=set_performance_profile_failed" "package=$pkg"
        return 1
    fi
    rewrite_performance_without_key "$pkg" "$mode"
    printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
        "$pkg" "$mode" \
        "$little_max" "$little_min" \
        "$big_max" "$big_min" \
        "$titan_max" "$titan_min" \
        "$mega_max" "$mega_min" \
        "$gpu_max" "$gpu_min" \
        >> "$PERFORMANCE_PROFILES"
    chmod 0664 "$PERFORMANCE_PROFILES" 2>/dev/null
    clear_performance_summary
    publish_performance_state
    log_line "performance profile saved: $pkg/$mode"
    set_status "daemon=running" "last=set_performance_profile" \
        "package=$pkg" "mode=$mode"
}

remove_performance_profile() {
    pkg="$1"
    mode="$2"
    if ! valid_package_name "$pkg" || ! valid_mode "$mode"; then
        set_status "daemon=running" "last=remove_performance_profile_failed"
        return 1
    fi
    rewrite_performance_without_key "$pkg" "$mode"
    clear_performance_summary
    publish_performance_state
    log_line "performance profile removed: $pkg/$mode"
    set_status "daemon=running" "last=remove_performance_profile" \
        "package=$pkg" "mode=$mode"
}

app_apk_path() {
    if [ -n "$ZUI_PERFCTL_APK_OVERRIDE" ] &&
        [ -s "$ZUI_PERFCTL_APK_OVERRIDE" ]; then
        printf '%s\n' "$ZUI_PERFCTL_APK_OVERRIDE"
        return 0
    fi
    pm path "$APP_PACKAGE" 2>/dev/null | sed -n 's/^package://p' | head -n 1
}

generate_performance_xml() {
    apk="$(app_apk_path)"
    if [ ! -s "$apk" ]; then
        log_line "XML generator APK missing"
        return 1
    fi
    rm -f "$PERFORMANCE_SUMMARY"
    if CLASSPATH="$apk" app_process /system/bin com.zui.perfctl.XmlProfileGenerator \
        "$DEFAULT_GAME_POLICY" "$DEFAULT_PERF_CONFIG" "$PERFORMANCE_PROFILES" \
        "$WORK_GAME_POLICY" "$WORK_PERF_CONFIG" \
        > "$PERFORMANCE_SUMMARY.tmp" 2>&1; then
        mv "$PERFORMANCE_SUMMARY.tmp" "$PERFORMANCE_SUMMARY"
        chmod 0664 "$WORK_GAME_POLICY" "$WORK_PERF_CONFIG" "$PERFORMANCE_SUMMARY" 2>/dev/null
        publish_performance_state
        log_line "performance XML generated"
        return 0
    fi
    mv "$PERFORMANCE_SUMMARY.tmp" "$PERFORMANCE_SUMMARY" 2>/dev/null
    publish_performance_state
    log_line "performance XML generation failed: $(tail -n 1 "$PERFORMANCE_SUMMARY" 2>/dev/null)"
    return 1
}

apply_performance() {
    if generate_performance_xml && apply_zuipp; then
        set_status "daemon=running" "last=apply_performance_ok"
        return 0
    fi
    set_status "daemon=running" "last=apply_performance_failed"
    return 1
}

export_logs() {
    publish_state
    export_text="ZuiperfCtl 运行记录
导出时间：$(ts)

[状态]
$(cat "$STATUS_FILE" 2>/dev/null)

[刷新率规则]
$(cat "$REFRESH_RULES" 2>/dev/null)

[性能配置]
$(cat "$PERFORMANCE_PROFILES" 2>/dev/null)

[XML 生成摘要]
$(cat "$PERFORMANCE_SUMMARY" 2>/dev/null)

[AsoulOpt 健康状态]
$(settings_get_clean "$ASOUL_HEALTH_KEY")

[守护服务日志末尾]
$(tail -n 120 "$LOG_FILE" 2>/dev/null)

[AsoulOpt 日志末尾]
$(tail -n 80 "$ASOUL_LOG" 2>/dev/null)"
    settings_put_quiet "$LOG_EXPORT_KEY" "$export_text"
    set_status "daemon=running" "last=export_logs"
}

archive_request() {
    file="$1"
    base="$(basename "$file")"
    stamp="$(date '+%Y%m%d_%H%M%S')"
    mkdir -p "$DONE_DIR"
    mv "$file" "$DONE_DIR/$stamp.$base" 2>/dev/null
}

prop_value() {
    key="$1"
    file="$2"
    sed -n "s/^$key=//p" "$file" 2>/dev/null | tail -n 1
}

handle_request() {
    source="$1"
    cmd="$2"
    rate="$3"
    pkg="$4"
    mode="$5"
    little_max="$6"
    little_min="$7"
    big_max="$8"
    big_min="$9"
    shift 9
    titan_max="$1"
    titan_min="$2"
    mega_max="$3"
    mega_min="$4"
    gpu_max="$5"
    gpu_min="$6"
    log_line "request: $source cmd=$cmd rate=$rate pkg=$pkg mode=$mode"

    case "$cmd" in
        status)
            publish_state
            set_status "daemon=running" "last=status"
            ;;
        learn_refresh) learn_refresh "$rate" ;;
        set_refresh) set_refresh_rate "$rate" ;;
        restore_refresh) restore_refresh_rate ;;
        remove_refresh_rule) remove_refresh_rule "$pkg" ;;
        set_performance_profile)
            set_performance_profile "$pkg" "$mode" \
                "$little_max" "$little_min" \
                "$big_max" "$big_min" \
                "$titan_max" "$titan_min" \
                "$mega_max" "$mega_min" \
                "$gpu_max" "$gpu_min"
            ;;
        remove_performance_profile) remove_performance_profile "$pkg" "$mode" ;;
        apply_performance) apply_performance ;;
        apply_zuipp) apply_zuipp ;;
        restore_zuipp) restore_zuipp ;;
        restart_zuipp) restart_zuipp ;;
        restart_asoul) restart_asoul ;;
        apply_asoul) apply_asoul ;;
        restore_asoul) restore_asoul ;;
        export_logs) export_logs ;;
        *)
            log_line "unknown request: $cmd"
            set_status "daemon=running" "last=unknown_request" "cmd=$cmd"
            ;;
    esac
    trim_log
}

process_request_file() {
    file="$1"
    [ -s "$file" ] || return 0
    cpu_max="$(prop_value cpu_max "$file")"
    cpu_min="$(prop_value cpu_min "$file")"
    little_max="$(prop_value little_max "$file")"
    little_min="$(prop_value little_min "$file")"
    big_max="$(prop_value big_max "$file")"
    big_min="$(prop_value big_min "$file")"
    titan_max="$(prop_value titan_max "$file")"
    titan_min="$(prop_value titan_min "$file")"
    mega_max="$(prop_value mega_max "$file")"
    mega_min="$(prop_value mega_min "$file")"
    if [ -n "$cpu_max" ] || [ -n "$cpu_min" ]; then
        little_max="${little_max:-$cpu_max}"
        little_min="${little_min:-$cpu_min}"
        big_max="${big_max:-$cpu_max}"
        big_min="${big_min:-$cpu_min}"
        titan_max="${titan_max:-$cpu_max}"
        titan_min="${titan_min:-$cpu_min}"
        mega_max="${mega_max:-$cpu_max}"
        mega_min="${mega_min:-$cpu_min}"
    fi
    handle_request "$file" \
        "$(prop_value cmd "$file")" \
        "$(prop_value rate "$file")" \
        "$(prop_value package "$file")" \
        "$(prop_value mode "$file")" \
        "$little_max" \
        "$little_min" \
        "$big_max" \
        "$big_min" \
        "$titan_max" \
        "$titan_min" \
        "$mega_max" \
        "$mega_min" \
        "$(prop_value gpu_max "$file")" \
        "$(prop_value gpu_min "$file")"
    archive_request "$file"
}

process_atomic_settings_request() {
    request="$(settings_get_clean "$REQ_TEXT_KEY")"
    if [ -z "$request" ] || [ "$request" = "$LAST_SETTINGS_REQUEST_TEXT" ]; then
        return 0
    fi
    LAST_SETTINGS_REQUEST_TEXT="$request"
    echo "$request" > "$LAST_REQUEST_FILE"
    chmod 0664 "$LAST_REQUEST_FILE" 2>/dev/null

    field_count="$(printf '%s\n' "$request" | awk -F'|' '{print NF}')"
    if [ "$field_count" -ne 9 ] && [ "$field_count" -ne 15 ]; then
        log_line "invalid atomic request field count: $field_count"
        return 1
    fi
    id="$(printf '%s\n' "$request" | cut -d '|' -f 1)"
    cmd="$(printf '%s\n' "$request" | cut -d '|' -f 2)"
    [ -n "$id" ] && [ -n "$cmd" ] || return 1
    if [ "$field_count" -eq 9 ]; then
        cpu_max="$(printf '%s\n' "$request" | cut -d '|' -f 6)"
        cpu_min="$(printf '%s\n' "$request" | cut -d '|' -f 7)"
        handle_request "settings:$id" "$cmd" \
            "$(printf '%s\n' "$request" | cut -d '|' -f 3)" \
            "$(printf '%s\n' "$request" | cut -d '|' -f 4)" \
            "$(printf '%s\n' "$request" | cut -d '|' -f 5)" \
            "$cpu_max" "$cpu_min" \
            "$cpu_max" "$cpu_min" \
            "$cpu_max" "$cpu_min" \
            "$cpu_max" "$cpu_min" \
            "$(printf '%s\n' "$request" | cut -d '|' -f 8)" \
            "$(printf '%s\n' "$request" | cut -d '|' -f 9)"
        return 0
    fi
    handle_request "settings:$id" "$cmd" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 3)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 4)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 5)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 6)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 7)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 8)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 9)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 10)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 11)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 12)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 13)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 14)" \
        "$(printf '%s\n' "$request" | cut -d '|' -f 15)"
}

boot_restore() {
    if [ -f "$ZUI_ENABLED" ]; then
        log_line "restoring enabled ZuiPP bind"
        apply_zuipp
    fi
    if [ -f "$ASOUL_ENABLED" ]; then
        log_line "restoring enabled AsoulOpt config bind"
        apply_asoul
    fi
}

init_request_state() {
    request="$(settings_get_clean "$REQ_TEXT_KEY")"
    if [ -s "$LAST_REQUEST_FILE" ]; then
        LAST_SETTINGS_REQUEST_TEXT="$(cat "$LAST_REQUEST_FILE" 2>/dev/null)"
    elif [ -n "$request" ]; then
        echo "$request" > "$LAST_REQUEST_FILE"
        chmod 0664 "$LAST_REQUEST_FILE" 2>/dev/null
        LAST_SETTINGS_REQUEST_TEXT="$request"
    fi
}

main_loop() {
    init_dirs
    init_request_state
    log_line "zui_perfctld v9 start"
    boot_restore
    set_refresh_rate "$BASE_REFRESH_RATE"
    publish_state
    set_status "daemon=running" "last=init"
    notify_quick_service

    while true; do
        process_atomic_settings_request
        process_request_file "$ADB_REQUEST"
        LOOP_TICKS=$((LOOP_TICKS + 1))
        if [ "$LOOP_TICKS" -ge 4 ]; then
            refresh_tick
            LOOP_TICKS=0
        fi
        HEALTH_TICKS=$((HEALTH_TICKS + 1))
        if [ "$HEALTH_TICKS" -ge 40 ]; then
            publish_asoul_health
            publish_xml_state
            HEALTH_TICKS=0
        fi
        sleep 0.25
    done
}

main_loop
