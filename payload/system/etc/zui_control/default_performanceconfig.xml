    <!-- 需要监控的状态节点定义。
         状态节点文件目录不固定，需要通过扫描指定目录，根据标记文件内容，找到节点所在目录
         name : 节点名称
         rootpath : 节点搜索的根目录
         statefilename : 状态节点文件名
         typefilename : 标记类型的文件名
         typevalue : 标记字符串
         maxdeepth : 最大搜索子目录深度 -->
    <StateFile name = "thermal.backthermal_zone"
        rootpath = "/sys/class/thermal"
        statefilename = "temp"
        typefilename="type"
        typevalue="user_front_temp"
        maxdeepth="1">
    </StateFile>
    <StateFile name = "thermal.thermal_zone"
        rootpath = "/sys/class/thermal"
        statefilename = "temp"
        typefilename="type"
        typevalue="user_front_temp"
        maxdeepth="1">
    </StateFile>

    <!--需要设置策略的节点定义。
        default表示设备默认值，
